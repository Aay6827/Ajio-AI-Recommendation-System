{
  "family": "ajio-recommender",
  "networkMode": "awsvpc",
  "requiresCompatibilities": ["FARGATE"],
  "cpu": "512",
  "memory": "1024",
  "executionRoleArn": "arn:aws:iam::867344477317:role/ecsTaskExecutionRole",
  "containerDefinitions": [
    {
      "name": "ajio-recommender",
      "image": "867344477317.dkr.ecr.ap-south-1.amazonaws.com/ajio-recommender:latest",
      "portMappings": [
        {
          "containerPort": 8000,
          "protocol": "tcp"
        }
      ],
      "environment": [
        {
          "name": "DATABASE_URL",
          "value": "postgresql+psycopg2://postgres:admin123@ajio-postgres.c5gowycis9cg.ap-south-1.rds.amazonaws.com:5432/ajio"
        }
      ],
      "logConfiguration": {
        "logDriver": "awslogs",
        "options": {
          "awslogs-group": "/ecs/ajio-recommender",
          "awslogs-region": "ap-south-1",
          "awslogs-stream-prefix": "ecs"
        }
      }
    }
  ]
}